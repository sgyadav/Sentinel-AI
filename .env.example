# Application Configuration
APP_NAME=SENTINEL AI
APP_VERSION=1.0.0
DEBUG=False

# Database
DATABASE_URL=sqlite:////data/sentinel.db
# For production, use: DATABASE_URL=postgresql://user:password@db:5432/sentinel

# JWT Security Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
SENTINEL_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Security
REQUIRE_HTTPS=False
PASSWORD_MIN_LENGTH=8

# Real-time Processing
REALTIME_ENABLED=True
WEBSOCKET_HEARTBEAT_INTERVAL=30

# Telemetry
HEARTBEAT_TIMEOUT=120

# Threat Intelligence APIs (Optional)
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
OTX_API_KEY=your_otx_api_key_here

# Email (for alerts)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Logging
LOG_LEVEL=INFO
